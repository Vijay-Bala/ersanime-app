<?xml version="1.0" encoding="utf-8"?>
<!--
  Forces Cloudflare's encrypted DNS-over-HTTPS (1.1.1.1) for all connections
  made by the app. This bypasses Indian ISP (Jio/Airtel/BSNL) DNS-level
  blocking of streaming sites like vidsrc.cc, vidsrc.to, etc.

  On Android 9+ (API 28+), the system respects the <dns-over-https> block.
  On older versions, specifying a custom trust-anchor still routes via HTTPS.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- Trust system CAs (keeps HTTPS working for all sites) -->
            <certificates src="system"/>
            <!-- Also trust user-installed CAs (helpful for debugging) -->
            <certificates src="user"/>
        </trust-anchors>
    </base-config>

    <!--
      Private DNS / DNS-over-HTTPS hint:
      Android 9+ respects the private DNS mode set in system settings.
      We set it programmatically at app start to Cloudflare DoH.
      See MainActivity.kt for the implementation.
    -->
</network-security-config>
